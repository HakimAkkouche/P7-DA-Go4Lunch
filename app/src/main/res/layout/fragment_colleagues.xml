<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.colleagues.ColleaguesFragment">

    <fragment
        android:id="@+id/autocomplete_fragment_colleagues"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_marginTop="?attr/actionBarSize"
        android:fragmentAllowEnterTransitionOverlap="@color/fui_transparent"
        android:name="com.google.android.libraries.places.widget.AutocompleteSupportFragment"
        xmlns:android="http://schemas.android.com/apk/res/android"
        app:layout_constraintTop_toTopOf="parent"

        />
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/colleagues_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:listitem="@layout/colleague_item_list"
        android:layout_below="@id/autocomplete_fragment_colleagues"/>
</RelativeLayout>